rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function adminData() {
      return get(/databases/$(database)/documents/roy_admins/$(request.auth.uid)).data;
    }

    function userData() {
      return get(/databases/$(database)/documents/roy_users/$(request.auth.uid)).data;
    }

    function isRoyAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/roy_admins/$(request.auth.uid))
        && adminData().active == true
        && adminData().role == 'admin';
    }

    function isActiveStaff() {
      return signedIn()
        && exists(/databases/$(database)/documents/roy_users/$(request.auth.uid))
        && userData().active == true;
    }

    function hasRole(role) {
      return isActiveStaff() && userData().role == role;
    }

    function adminOrRole(role) {
      return isRoyAdmin() || hasRole(role);
    }

    match /roy_admins/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update, delete: if isRoyAdmin();
    }

    match /roy_users/{userId} {
      allow read: if isRoyAdmin() || (signedIn() && request.auth.uid == userId);
      allow create, update, delete: if isRoyAdmin();
    }

    match /roy_products/{docId} {
      allow read: if true;
      allow create, update, delete: if isRoyAdmin() || hasRole('Inventario') || hasRole('Contenido');
    }

    match /roy_product_images/{docId} {
      allow read: if true;
      allow create, update, delete: if isRoyAdmin() || hasRole('Inventario') || hasRole('Contenido');
    }

    match /roy_categories/{docId} {
      allow read: if true;
      allow create, update, delete: if isRoyAdmin() || hasRole('Inventario') || hasRole('Contenido');
    }

    match /roy_media/{docId} {
      allow read: if true;
      allow create, update, delete: if isRoyAdmin() || hasRole('Contenido');
    }

    match /roy_promotions/{docId} {
      allow read: if true;
      allow create, update, delete: if isRoyAdmin() || hasRole('Contenido') || hasRole('Ventas');
    }

    match /roy_settings/{docId} {
      allow read: if true;
      allow create, update, delete: if isRoyAdmin() || hasRole('Contenido');
    }

    match /roy_shipping/{docId} {
      allow read: if true;
      allow create, update, delete: if isRoyAdmin() || hasRole('Ventas');
    }

    match /roy_orders/{docId} {
      allow create: if true;
      allow read, update: if isRoyAdmin() || hasRole('Ventas') || hasRole('Inventario') || hasRole('Atención al cliente');
      allow delete: if isRoyAdmin() || hasRole('Ventas');
    }

    match /roy_messages/{docId} {
      allow create: if true;
      allow read, update, delete: if isRoyAdmin() || hasRole('Ventas') || hasRole('Atención al cliente');
    }

    match /roy_reviews/{docId} {
      allow create: if true;
      allow read: if resource.data.approved == true || isRoyAdmin() || hasRole('Atención al cliente');
      allow update, delete: if isRoyAdmin() || hasRole('Atención al cliente');
    }

    match /roy_inventory/{docId} {
      allow read, create, update, delete: if isRoyAdmin() || hasRole('Inventario');
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
