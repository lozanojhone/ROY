rules_version = '2';
service cloud.firestore {
 match /databases/{database}/documents {
  function signedIn(){ return request.auth != null; }
  function owner(){ return signedIn() && request.auth.uid == 'A39oqjxvtLWOJdya7ldpkLDghtA3'; }
  function adminDoc(){ return signedIn() && exists(/databases/$(database)/documents/roy_admins/$(request.auth.uid)) && get(/databases/$(database)/documents/roy_admins/$(request.auth.uid)).data.active == true && get(/databases/$(database)/documents/roy_admins/$(request.auth.uid)).data.role == 'admin'; }
  function staffDoc(){ return signedIn() && exists(/databases/$(database)/documents/roy_users/$(request.auth.uid)) && get(/databases/$(database)/documents/roy_users/$(request.auth.uid)).data.active == true; }
  function manager(){ return owner() || adminDoc(); }
  function panelUser(){ return manager() || staffDoc(); }
  match /roy_admins/{id}{ allow read: if signedIn() && (request.auth.uid==id || manager()); allow write: if owner(); }
  match /roy_users/{id}{ allow read: if panelUser(); allow create,update,delete: if manager(); }
  match /roy_products/{id}{ allow read: if true; allow write: if panelUser(); }
  match /roy_product_images/{id}{ allow read: if true; allow write: if panelUser(); }
  match /roy_categories/{id}{ allow read: if true; allow write: if panelUser(); }
  match /roy_media/{id}{ allow read: if true; allow write: if panelUser(); }
  match /roy_promotions/{id}{ allow read: if true; allow write: if panelUser(); }
  match /roy_settings/{id}{ allow read: if true; allow write: if panelUser(); }
  match /roy_shipping/{id}{ allow read: if true; allow write: if panelUser(); }
  match /roy_orders/{id}{ allow create: if true; allow read,update,delete: if panelUser(); }
  match /roy_messages/{id}{ allow create: if true; allow read,update,delete: if panelUser(); }
  match /roy_reviews/{id}{ allow create: if true; allow read: if panelUser() || resource.data.approved == true; allow update,delete: if panelUser(); }
  match /roy_inventory/{id}{ allow read,write: if panelUser(); }
  match /{document=**}{ allow read,write: if false; }
 }
}
